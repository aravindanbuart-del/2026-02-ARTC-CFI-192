def clean_and_style_ax(ax, title, xlabel, ylabel):
    ax.set_title(title, fontsize=STYLING['title_size'], fontweight='bold', pad=20)
    ax.set_xlabel(xlabel, fontsize=STYLING['label_size'], fontweight='bold')
    ax.set_ylabel(ylabel, fontsize=STYLING['label_size'], fontweight='bold')
    ax.tick_params(axis='both', which='major', labelsize=STYLING['tick_size'])
    ax.grid(False)
    for label in (ax.get_xticklabels() + ax.get_yticklabels()):
        label.set_fontweight('bold')
    if ax.get_legend():
        plt.setp(ax.get_legend().get_texts(), fontsize=STYLING['legend_size'], fontweight='bold')

def add_bar_values(ax, precision='.3f'):
    for p in ax.patches:
        val = p.get_height()
        if val > 0:
            ax.annotate(format(val, precision), 
                       (p.get_x() + p.get_width() / 2., val), 
                       ha = 'center', va = 'center', 
                       xytext = (0, 10), 
                       textcoords = 'offset points',
                       fontsize=14, fontweight='bold')

